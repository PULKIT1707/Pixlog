# GitHub App (create at github.com/settings/apps/new)
# Permissions needed: Contents (Read/Write), Metadata (Read), Email addresses (Read)
GITHUB_APP_ID=
GITHUB_APP_SLUG=pixlog
GITHUB_APP_PRIVATE_KEY=        # Full PEM content — paste with \n as literal newlines
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Supabase — find at supabase.com/dashboard/project/<id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=     # Never expose this in the browser

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
